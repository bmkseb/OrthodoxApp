# Supabase — ingestion scripts (local only, never commit .env)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Supabase — Expo app (anon key is safe in the client with RLS enabled)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# YouTube — ingestion scripts (local only)
YOUTUBE_API_KEY=your-youtube-data-api-key

# YouTube — optional live refresh in the Expo app (otherwise use build:mezmur-youtube-stats)
EXPO_PUBLIC_YOUTUBE_API_KEY=your-youtube-data-api-key